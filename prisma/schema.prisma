// =============================================================
// HIS — Complete Prisma Schema
// Platform layer (SuperAdmin) + Hospital layer (OPD MVP)
// Two PostgreSQL schemas: "platform" + "hospital"
// =============================================================

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["platform", "hospital"]
}

// =============================================================
// PLATFORM SCHEMA — SuperAdmin manages this
// =============================================================

enum PlatformRole {
  SUPER_ADMIN
  SUPPORT_ADMIN
  @@schema("platform")
}

enum HospitalStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  @@schema("platform")
}

enum DeploymentMode {
  SAAS
  HYBRID
  ON_PREMISE
  @@schema("platform")
}

enum ComponentType {
  MODULE
  SUB_MODULE
  FEATURE
  @@schema("platform")
}

enum PackageAssignmentStatus {
  ACTIVE
  EXPIRED
  CANCELLED
  @@schema("platform")
}

// ------- Platform Users (SuperAdmin team) -------

model PlatformUser {
  id           Int          @id @default(autoincrement())
  email        String       @unique
  passwordHash String
  role         PlatformRole
  isActive     Boolean      @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  refreshTokens    RefreshToken[]
  createdHospitals Hospital[]       @relation("CreatedBy")
  assignedPackages AssignedPackage[] @relation("AssignedBy")

  @@map("platform_users")
  @@schema("platform")
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      PlatformUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String
  deviceInfo String?                      // "Chrome, Windows"
  ipAddress  String?
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@map("refresh_tokens")
  @@schema("platform")
}

// ------- Hospital (Tenant) -------

model Hospital {
  id             Int            @id @default(autoincrement())
  name           String
  code           String         @unique  // "CCL" — used in UHID: CCL-2024-00452
  subdomain      String         @unique  // "city-clinic" → city-clinic.yourhis.com
  email          String         @unique
  phone          String?
  address        String?
  city           String?
  state          String?
  pincode        String?
  gstin          String?                 // for GST billing
  panNumber      String?
  logoUrl        String?
  timezone       String         @default("Asia/Kolkata")
  deploymentMode DeploymentMode @default(SAAS)
  licenseKey     String?        @unique  // on-premise only
  status         HospitalStatus @default(ACTIVE)
  createdBy      Int?
  creator        PlatformUser?  @relation("CreatedBy", fields: [createdBy], references: [id])
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  assignments AssignedPackage[]

  @@map("hospitals")
  @@schema("platform")
}

// ------- System Components (Module tree) -------

model SystemComponent {
  id           Int             @id @default(autoincrement())
  parentId     Int?
  parent       SystemComponent?  @relation("ComponentHierarchy", fields: [parentId], references: [id])
  children     SystemComponent[] @relation("ComponentHierarchy")
  code         String          @unique  // "opd", "opd.registration", "opd.queue"
  name         String
  type         ComponentType
  iconName     String?                  // "ti-stethoscope" — for sidebar
  route        String?                  // "/opd/dashboard" — frontend route
  displayOrder Int             @default(0)
  isActive     Boolean         @default(true)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  packageComponents PackageComponent[]

  @@map("system_components")
  @@schema("platform")
}

// ------- Packages -------

model Package {
  id           Int      @id @default(autoincrement())
  name         String   @unique
  description  String?
  monthlyPrice Decimal? @db.Decimal(10, 2)
  yearlyPrice  Decimal? @db.Decimal(10, 2)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  components  PackageComponent[]
  limits      PackageLimit[]
  assignments AssignedPackage[]

  @@map("packages")
  @@schema("platform")
}

model PackageComponent {
  id          Int      @id @default(autoincrement())
  packageId   Int
  componentId Int
  package     Package         @relation(fields: [packageId], references: [id], onDelete: Cascade)
  component   SystemComponent @relation(fields: [componentId], references: [id], onDelete: Cascade)
  createdAt   DateTime        @default(now())

  @@unique([packageId, componentId])
  @@map("package_components")
  @@schema("platform")
}

model PackageLimit {
  id         Int      @id @default(autoincrement())
  packageId  Int
  package    Package  @relation(fields: [packageId], references: [id], onDelete: Cascade)
  limitKey   String                // "max_doctors", "max_patients_per_day"
  limitValue String                // "5", "100", "unlimited"
  createdAt  DateTime @default(now())

  @@unique([packageId, limitKey])
  @@map("package_limits")
  @@schema("platform")
}

model AssignedPackage {
  id         Int                     @id @default(autoincrement())
  hospitalId Int
  packageId  Int
  hospital   Hospital  @relation(fields: [hospitalId], references: [id], onDelete: Cascade)
  package    Package   @relation(fields: [packageId], references: [id], onDelete: Cascade)
  status     PackageAssignmentStatus @default(ACTIVE)
  startDate  DateTime
  endDate    DateTime?
  assignedBy Int?
  assigner   PlatformUser? @relation("AssignedBy", fields: [assignedBy], references: [id])
  notes      String?
  cancelledAt DateTime?
  cancelledBy Int?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([hospitalId])
  @@index([packageId])
  @@index([hospitalId, status])
  @@map("assigned_packages")
  @@schema("platform")
}

// =============================================================
// HOSPITAL SCHEMA — Each hospital's operational data
// hospitalId (Int) is the tenant key — links to platform.Hospital
// =============================================================

enum UserRole {
  HOSPITAL_ADMIN
  DOCTOR
  NURSE
  RECEPTIONIST
  PHARMACIST
  LAB_TECH
  BILLING_STAFF
  @@schema("hospital")
}

enum Gender {
  MALE
  FEMALE
  OTHER
  @@schema("hospital")
}

enum BloodGroup {
  A_POS
  A_NEG
  B_POS
  B_NEG
  O_POS
  O_NEG
  AB_POS
  AB_NEG
  UNKNOWN
  @@schema("hospital")
}

enum VisitType {
  OPD
  FOLLOW_UP
  EMERGENCY
  WALKIN
  REVIEW
  @@schema("hospital")
}

enum VisitStatus {
  REGISTERED
  WAITING
  VITALS_DONE
  IN_CONSULTATION
  CONSULTATION_DONE
  BILLING_PENDING
  COMPLETED
  CANCELLED
  @@schema("hospital")
}

enum TokenStatus {
  WAITING
  CALLED
  IN_CONSULTATION
  DONE
  SKIPPED
  CANCELLED
  @@schema("hospital")
}

enum AppointmentStatus {
  SCHEDULED
  CONFIRMED
  ARRIVED
  IN_QUEUE
  COMPLETED
  CANCELLED
  NO_SHOW
  @@schema("hospital")
}

enum AppointmentSource {
  COUNTER
  ONLINE
  PHONE
  WALKIN
  @@schema("hospital")
}

enum BillStatus {
  DRAFT
  PENDING
  PARTIAL
  PAID
  REFUNDED
  WAIVED
  CREDIT
  @@schema("hospital")
}

enum PaymentMode {
  CASH
  CARD
  UPI
  NETBANKING
  CHEQUE
  NEFT
  INSURANCE
  @@schema("hospital")
}

enum LabOrderStatus {
  ORDERED
  SAMPLE_COLLECTED
  PROCESSING
  RESULTED
  CANCELLED
  @@schema("hospital")
}

// ------- Hospital Users (Staff) -------

model HospitalUser {
  id           String   @id @default(uuid())
  hospitalId   Int                          // FK → platform.Hospital.id
  name         String
  email        String
  phone        String?
  passwordHash String
  role         UserRole
  department   String?
  signatureUrl String?                      // for prescriptions (doctors)
  isActive     Boolean  @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // relations
  doctorProfile      Doctor?
  visitRegistrations Visit[]       @relation("RegisteredBy")
  vitalsRecorded     Vitals[]
  appointmentsBooked Appointment[] @relation("BookedBy")
  billsCreated       Bill[]

  @@unique([hospitalId, email])
  @@index([hospitalId, role])
  @@map("hospital_users")
  @@schema("hospital")
}

// ------- Doctor (extends HospitalUser) -------

model Doctor {
  id               String   @id @default(uuid())
  hospitalId       Int
  userId           String   @unique
  user             HospitalUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  name             String
  specialization   String?
  qualification    String?
  registrationNo   String?                  // MCI number
  consultationFee  Decimal  @default(0) @db.Decimal(8, 2)
  followUpFee      Decimal  @default(0) @db.Decimal(8, 2)
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  schedules    DoctorSchedule[]
  leaves       DoctorLeave[]
  visits       Visit[]
  appointments Appointment[]
  emrRecords   EmrRecord[]
  prescriptions Prescription[]

  @@index([hospitalId])
  @@map("doctors")
  @@schema("hospital")
}

model DoctorSchedule {
  id              String   @id @default(uuid())
  hospitalId      Int
  doctorId        String
  doctor          Doctor   @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  dayOfWeek       Int                        // 0=Sun ... 6=Sat
  startTime       String                     // "09:00"
  endTime         String                     // "13:00"
  slotDurationMin Int      @default(15)
  maxPatients     Int      @default(20)
  isActive        Boolean  @default(true)

  @@unique([doctorId, dayOfWeek])
  @@index([hospitalId, doctorId])
  @@map("doctor_schedules")
  @@schema("hospital")
}

model DoctorLeave {
  id         String   @id @default(uuid())
  hospitalId Int
  doctorId   String
  doctor     Doctor   @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  leaveDate  DateTime @db.Date
  reason     String?
  createdAt  DateTime @default(now())

  @@unique([doctorId, leaveDate])
  @@map("doctor_leaves")
  @@schema("hospital")
}

// ------- Patient -------

model Patient {
  id               String     @id @default(uuid())
  hospitalId       Int
  uhid             String                     // "CCL-2024-00452"
  salutation       String?                    // Mr/Mrs/Ms/Baby
  firstName        String
  lastName         String?
  phone            String
  alternatePhone   String?
  email            String?
  dateOfBirth      DateTime?  @db.Date
  age              Int?                       // if DOB unknown
  ageUnit          String     @default("years")  // years|months|days
  gender           Gender
  bloodGroup       BloodGroup @default(UNKNOWN)
  address          String?
  city             String?
  state            String?
  pincode          String?
  occupation       String?
  maritalStatus    String?
  abhaId           String?                    // Ayushman Bharat ID
  aadhaarLast4     String?
  emergencyName    String?
  emergencyPhone   String?
  emergencyRelation String?
  knownAllergies   String[]   @default([])
  chronicConditions String[]  @default([])
  referredBy       String?
  photoUrl         String?
  isActive         Boolean    @default(true)
  deletedAt        DateTime?
  createdBy        String?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  visits       Visit[]
  appointments Appointment[]
  documents    PatientDocument[]
  vitals       Vitals[]
  bills        Bill[]

  @@unique([hospitalId, uhid])
  @@index([hospitalId, phone])
  @@index([hospitalId, deletedAt])
  @@map("patients")
  @@schema("hospital")
}

// ------- Visit (OPD core) -------

model Visit {
  id                   String      @id @default(uuid())
  hospitalId           Int
  patientId            String
  patient              Patient     @relation(fields: [patientId], references: [id])
  doctorId             String?
  doctor               Doctor?     @relation(fields: [doctorId], references: [id])
  visitNumber          String                     // "V-2024-001042"
  visitDate            DateTime    @db.Date
  visitTime            DateTime?   @db.Time
  visitType            VisitType
  status               VisitStatus @default(REGISTERED)
  isEmergency          Boolean     @default(false)
  isMlc                Boolean     @default(false)
  mlcNumber            String?
  chiefComplaint       String?                    // filled by nurse
  referredBy           String?
  referredTo           String?
  registrationComplete Boolean     @default(true) // false = emergency quick-reg
  registeredBy         String?
  registeredByUser     HospitalUser? @relation("RegisteredBy", fields: [registeredBy], references: [id])
  deletedAt            DateTime?
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt

  token        Token?
  vitals       Vitals?
  emrRecord    EmrRecord?
  prescription Prescription?
  labOrders    LabOrder[]
  bill         Bill?
  appointment  Appointment?

  @@unique([hospitalId, visitNumber])
  @@index([hospitalId, visitDate])
  @@index([hospitalId, patientId])
  @@index([hospitalId, doctorId, visitDate])
  @@index([hospitalId, status])
  @@map("visits")
  @@schema("hospital")
}

// ------- Token / Queue -------

model Token {
  id                  String      @id @default(uuid())
  hospitalId          Int
  visitId             String      @unique
  visit               Visit       @relation(fields: [visitId], references: [id])
  doctorId            String
  tokenNumber         Int
  tokenDate           DateTime    @db.Date
  status              TokenStatus @default(WAITING)
  calledAt            DateTime?
  consultationStart   DateTime?
  consultationEnd     DateTime?
  waitMinutes         Int?        // calculated when called

  @@unique([hospitalId, doctorId, tokenNumber, tokenDate])
  @@index([hospitalId, doctorId, tokenDate, status])
  @@map("tokens")
  @@schema("hospital")
}

// ------- Vitals -------

model Vitals {
  id               String   @id @default(uuid())
  hospitalId       Int
  visitId          String   @unique
  visit            Visit    @relation(fields: [visitId], references: [id])
  patientId        String
  patient          Patient  @relation(fields: [patientId], references: [id])
  recordedBy       String?
  recordedByUser   HospitalUser? @relation(fields: [recordedBy], references: [id])
  bpSystolic       Int?
  bpDiastolic      Int?
  pulseRate        Int?
  temperature      Decimal? @db.Decimal(4, 1)
  temperatureUnit  String   @default("F")
  spo2             Int?
  weight           Decimal? @db.Decimal(5, 2)
  height           Decimal? @db.Decimal(5, 2)
  bmi              Decimal? @db.Decimal(4, 1)    // auto-calculated
  bloodSugar       Decimal? @db.Decimal(6, 2)
  bloodSugarType   String?                       // fasting|pp|random
  respiratoryRate  Int?
  nurseNotes       String?
  recordedAt       DateTime @default(now())

  @@index([hospitalId, patientId])
  @@map("vitals")
  @@schema("hospital")
}

// ------- Appointments -------

model Appointment {
  id              String            @id @default(uuid())
  hospitalId      Int
  patientId       String
  patient         Patient           @relation(fields: [patientId], references: [id])
  doctorId        String
  doctor          Doctor            @relation(fields: [doctorId], references: [id])
  appointmentDate DateTime          @db.Date
  appointmentTime String                         // "10:30"
  slotDurationMin Int               @default(15)
  visitType       VisitType         @default(OPD)
  reason          String?
  source          AppointmentSource @default(COUNTER)
  status          AppointmentStatus @default(SCHEDULED)
  confirmedAt     DateTime?
  arrivedAt       DateTime?
  visitId         String?           @unique       // linked when patient arrives
  visit           Visit?            @relation(fields: [visitId], references: [id])
  reminderSentAt  DateTime?
  bookedBy        String?
  bookedByUser    HospitalUser?     @relation("BookedBy", fields: [bookedBy], references: [id])
  cancellationReason String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([hospitalId, doctorId, appointmentDate])
  @@index([hospitalId, patientId])
  @@index([hospitalId, status])
  @@map("appointments")
  @@schema("hospital")
}

// ------- EMR -------

model EmrRecord {
  id            String   @id @default(uuid())
  hospitalId    Int
  visitId       String   @unique
  visit         Visit    @relation(fields: [visitId], references: [id])
  patientId     String
  doctorId      String
  doctor        Doctor   @relation(fields: [doctorId], references: [id])

  // SOAP
  subjective    String?
  objective     String?
  assessment    String?
  // Structured diagnoses: [{icd10Code, icd10Name, type: "primary"|"secondary"}]
  diagnoses     Json     @default("[]")
  plan          String?
  doctorNotes   String?              // internal — not on prescription
  advice        String?              // patient-facing
  dietInstructions String?
  followUpDays  Int?
  followUpReason String?
  referralNote  String?

  status        String   @default("draft")   // draft|completed|signed
  signedAt      DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([hospitalId, patientId])
  @@map("emr_records")
  @@schema("hospital")
}

// ------- Prescription -------

model Prescription {
  id               String   @id @default(uuid())
  hospitalId       Int
  visitId          String   @unique
  visit            Visit    @relation(fields: [visitId], references: [id])
  patientId        String
  doctorId         String
  doctor           Doctor   @relation(fields: [doctorId], references: [id])
  prescriptionNo   String                    // "RX-2024-004521"
  // drugs: [{drugName, genericName, strength, form, dose,
  //          frequency, duration, qty, route, instructions, isSos}]
  drugs            Json
  specialInstructions String?
  pdfUrl           String?
  whatsappSentAt   DateTime?
  printCount       Int      @default(0)
  pharmacyType     String   @default("inhouse")  // inhouse|external
  status           String   @default("active")   // active|dispensed|cancelled
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  dispensingRecord DispensingRecord?

  @@unique([hospitalId, prescriptionNo])
  @@index([hospitalId, patientId])
  @@map("prescriptions")
  @@schema("hospital")
}

// ------- Lab Orders -------

model LabOrder {
  id                String       @id @default(uuid())
  hospitalId        Int
  visitId           String
  visit             Visit        @relation(fields: [visitId], references: [id])
  patientId         String
  doctorId          String
  orderNo           String                     // "LO-2024-008821"
  // tests: [{testCode, testName, testCategory, urgency, specialInstructions}]
  tests             Json
  orderType         String       @default("inhouse")  // inhouse|external
  externalLabName   String?
  requisitionPdfUrl String?
  status            LabOrderStatus @default(ORDERED)
  resultPdfUrl      String?
  // resultData: structured values if lab API: [{testName, value, unit, normalRange, isAbnormal}]
  resultData        Json?
  resultUploadedAt  DateTime?
  resultUploadedBy  String?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  @@unique([hospitalId, orderNo])
  @@index([hospitalId, patientId])
  @@index([hospitalId, status])
  @@map("lab_orders")
  @@schema("hospital")
}

// ------- Patient Documents -------

model PatientDocument {
  id             String   @id @default(uuid())
  hospitalId     Int
  patientId      String
  patient        Patient  @relation(fields: [patientId], references: [id])
  visitId        String?                     // null = standalone upload
  docType        String                      // lab_report|xray|discharge|prescription|other
  source         String                      // inhouse|external_upload|patient_self
  sourceHospital String?
  reportDate     DateTime? @db.Date
  fileUrl        String
  fileType       String                      // pdf|image|dicom
  tags           Json     @default("[]")     // ["cbc","hemoglobin"]
  uploadedBy     String?                     // userId or "patient_self"
  createdAt      DateTime @default(now())

  @@index([hospitalId, patientId])
  @@map("patient_documents")
  @@schema("hospital")
}

// ------- Billing -------

model Bill {
  id             String     @id @default(uuid())
  hospitalId     Int
  visitId        String     @unique
  visit          Visit      @relation(fields: [visitId], references: [id])
  patientId      String
  patient        Patient    @relation(fields: [patientId], references: [id])
  billNo         String                         // "BILL-2024-009821"
  billDate       DateTime   @db.Date
  subtotal       Decimal    @default(0) @db.Decimal(10, 2)
  discountAmount Decimal    @default(0) @db.Decimal(10, 2)
  discountReason String?
  taxAmount      Decimal    @default(0) @db.Decimal(10, 2)
  totalAmount    Decimal    @default(0) @db.Decimal(10, 2)
  paidAmount     Decimal    @default(0) @db.Decimal(10, 2)
  outstanding    Decimal    @default(0) @db.Decimal(10, 2)
  status         BillStatus @default(PENDING)
  billingType    String     @default("cash")   // cash|insurance|credit|tpa
  tpaName        String?
  tpaClaimNo     String?
  billPdfUrl     String?
  createdBy      String?
  createdByUser  HospitalUser? @relation(fields: [createdBy], references: [id])
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  lineItems BillLineItem[]
  payments  Payment[]

  @@unique([hospitalId, billNo])
  @@index([hospitalId, status])
  @@index([hospitalId, patientId])
  @@map("bills")
  @@schema("hospital")
}

model BillLineItem {
  id          String   @id @default(uuid())
  hospitalId  Int
  billId      String
  bill        Bill     @relation(fields: [billId], references: [id], onDelete: Cascade)
  // item_type: consultation|pharmacy|lab|procedure|other
  itemType    String
  itemCode    String?
  itemName    String
  quantity    Decimal  @default(1) @db.Decimal(8, 2)
  unitRate    Decimal  @db.Decimal(10, 2)
  amount      Decimal  @db.Decimal(10, 2)
  gstRate     Decimal  @default(0) @db.Decimal(5, 2)
  gstAmount   Decimal  @default(0) @db.Decimal(10, 2)
  discount    Decimal  @default(0) @db.Decimal(10, 2)
  netAmount   Decimal  @db.Decimal(10, 2)
  hsnSacCode  String?
  referenceId String?                    // prescriptionId or labOrderId
  createdAt   DateTime @default(now())

  @@index([billId])
  @@map("bill_line_items")
  @@schema("hospital")
}

model Payment {
  id                String      @id @default(uuid())
  hospitalId        Int
  billId            String
  bill              Bill        @relation(fields: [billId], references: [id])
  patientId         String
  paymentNo         String                     // "PMT-2024-012341"
  amount            Decimal     @db.Decimal(10, 2)
  paymentMode       PaymentMode
  paymentReference  String?                    // UPI txn ID, card last 4
  paymentDate       DateTime    @db.Date
  collectedBy       String?
  notes             String?
  createdAt         DateTime    @default(now())

  @@unique([hospitalId, paymentNo])
  @@index([billId])
  @@map("payments")
  @@schema("hospital")
}

// ------- Pharmacy (Basic) -------

model PharmacyInventory {
  id                String   @id @default(uuid())
  hospitalId        Int
  drugName          String
  genericName       String?
  strength          String?
  form              String?                     // tablet|capsule|syrup
  batchNo           String?
  expiryDate        DateTime? @db.Date
  quantityAvailable Int       @default(0)
  minStockLevel     Int       @default(10)
  unitPrice         Decimal   @db.Decimal(8, 2)
  mrp               Decimal   @db.Decimal(8, 2)
  isActive          Boolean   @default(true)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([hospitalId])
  @@index([hospitalId, expiryDate])
  @@map("pharmacy_inventory")
  @@schema("hospital")
}

model DispensingRecord {
  id             String   @id @default(uuid())
  hospitalId     Int
  prescriptionId String   @unique
  prescription   Prescription @relation(fields: [prescriptionId], references: [id])
  visitId        String
  patientId      String
  dispensedBy    String?
  // drugsDispensed: [{drugName, qtyPrescribed, qtyDispensed,
  //                   batchNo, expiry, unitPrice, totalPrice, isPartial}]
  drugsDispensed Json
  totalAmount    Decimal  @db.Decimal(10, 2)
  pharmacyType   String   @default("inhouse")  // inhouse|external
  externalPharmacyName String?
  status         String   @default("pending")  // pending|partial|complete|cancelled
  dispensedAt    DateTime?
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([hospitalId, patientId])
  @@map("dispensing_records")
  @@schema("hospital")
}

// ------- Notifications -------

model NotificationLog {
  id                String   @id @default(uuid())
  hospitalId        Int
  patientId         String?
  eventType         String   // appointment_confirmed|prescription_sent|etc
  channel           String   // whatsapp|sms|email
  phone             String?
  messageBody       String
  status            String   @default("pending")  // pending|sent|delivered|failed
  provider          String?                        // msg91|twilio
  providerMessageId String?
  errorMessage      String?
  sentAt            DateTime?
  deliveredAt       DateTime?
  createdAt         DateTime @default(now())

  @@index([hospitalId, patientId])
  @@index([hospitalId, status])
  @@map("notification_logs")
  @@schema("hospital")
}

// ------- Audit Log -------

model AuditLog {
  id          String   @id @default(uuid())
  hospitalId  Int?                             // null = platform-level action
  userId      String?
  action      String                           // CREATE|UPDATE|DELETE|VIEW|PRINT
  resource    String                           // patients|visits|emr|bills
  resourceId  String?
  oldValue    Json?
  newValue    Json?
  ipAddress   String?
  userAgent   String?
  notes       String?
  createdAt   DateTime @default(now())

  @@index([hospitalId, resource, resourceId])
  @@index([hospitalId, userId, createdAt])
  @@map("audit_logs")
  @@schema("hospital")
}
